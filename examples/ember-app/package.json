{
  "name": "ember-app",
  "version": "0.0.0",
  "private": true,
  "description": "Small description for ember-app goes here",
  "repository": "",
  "license": "MIT",
  "author": "",
  "directories": {
    "doc": "doc",
    "test": "tests"
  },
  "scripts": {
    "build": "ember build --environment=production",
    "lint": "npm-run-all --aggregate-output --continue-on-error --parallel \"lint:!(fix)\"",
    "lint:fix": "npm-run-all --aggregate-output --continue-on-error --parallel lint:*:fix",
    "lint:hbs": "ember-template-lint .",
    "lint:hbs:fix": "ember-template-lint . --fix",
    "lint:js": "eslint . --cache",
    "lint:js:fix": "eslint . --fix",
    "start": "ember serve",
    "test": "npm-run-all lint test:*",
    "test:ember": "ember test",
    "build-muon": "cd muon && rollup -c"
  },
  "devDependencies": {
    "@babel/core": "^7.28.0",
    "@babel/eslint-parser": "^7.28.0",
    "@ember/optional-features": "^2.2.0",
    "@ember/test-helpers": "^5.4.1",
    "@glimmer/component": "^2.0.0",
    "@glimmer/tracking": "^1.1.2",
    "@muonic/muon": "file:../../packages/muon",
    "broccoli-asset-rev": "^3.0.0",
    "ember-auto-import": "^2.13.1",
    "ember-cli": "~6.12.0",
    "ember-cli-app-version": "^7.0.0",
    "ember-cli-babel": "^8.2.0",
    "ember-cli-dependency-checker": "^3.3.3",
    "ember-cli-htmlbars": "^7.0.0",
    "ember-cli-inject-live-reload": "^2.1.0",
    "ember-cli-sri": "^2.1.1",
    "ember-cli-terser": "^4.0.2",
    "ember-composable-helpers": "^5.0.0",
    "ember-data": "~5.5.0",
    "ember-load-initializers": "^3.0.1",
    "ember-page-title": "^9.0.0",
    "ember-qunit": "^9.0.4",
    "ember-resolver": "^13.2.0",
    "ember-source": "~6.12.0",
    "ember-template-lint": "^7.9.3",
    "ember-truth-helpers": "^4.0.2",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-ember": "^12.5.0",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-qunit": "^8.2.6",
    "loader.js": "^4.7.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.3",
    "qunit": "^2.25.0",
    "qunit-dom": "^3.5.1",
    "rollup": "^2.80.0",
    "webpack": "^5.106.0"
  },
  "engines": {
    "node": ">=22.0.0 <23.0.0"
  },
  "ember": {
    "edition": "octane"
  }
}
